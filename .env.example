# Copy this file to backend/.env and fill in your keys.

# LLM — one of the two keys below is required. Prism auto-selects Gemini
# when GEMINI_API_KEY is set (free tier, no credit card):
#   https://aistudio.google.com/apikey
GEMINI_API_KEY=

# Optional: Anthropic API key (paid). Set LLM_PROVIDER=anthropic to use it.
# https://console.anthropic.com/
ANTHROPIC_API_KEY=

# FRED API key — used for macro time series (rates, CPI, commodities, global).
# Free, instant signup: https://fred.stlouisfed.org/docs/api/api_key.html
FRED_API_KEY=

# SEC EDGAR requires a descriptive User-Agent with a contact email.
# Format: "AppName contact@email.com"
EDGAR_USER_AGENT=Prism Research your-email@example.com
